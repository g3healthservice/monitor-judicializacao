# === DataJud (Base Nacional de Dados do Poder Judiciario / CNJ) ===
# Chave PUBLICA disponibilizada pelo CNJ na Wiki do DataJud.
# NUNCA versionar a chave real. Copie este arquivo para .env e preencha.
DATAJUD_API_KEY=

# === Parametro economico (Tema 1.234) ===
# Salario minimo vigente. Os limiares 7 SM e 210 SM sao DERIVADOS deste valor.
SALARIO_MINIMO=1518.00

# === Banco ===
DATABASE_URL=sqlite:///monitor.db

# === Alertas por e-mail (opcional) ===
ALERT_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL_TO=

# === Ingestao ===
# Janela inicial (dias) para a primeira execucao sem checkpoint.
INGEST_LOOKBACK_DIAS=365
INGEST_PAGE_SIZE=100
HTTP_MAX_RETRIES=5
HTTP_TIMEOUT_S=30

# === Logging ===
LOG_LEVEL=INFO
